{
  "rewrites": [
    {
      "source": "/open-notify/(.*)",
      "destination": "http://api.open-notify.org/$1"
    },
    {
      "source": "/hf-api/(.*)",
      "destination": "https://router.huggingface.co/$1"
    },
    {
      "source": "/news-api/(.*)",
      "destination": "https://newsapi.org/v2/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
